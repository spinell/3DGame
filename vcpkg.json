{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "dependencies": [
    {
      "name": "sdl2",
      "version>=": "2.30.10",
      "default-features": false,
      "features": ["x11", "wayland", "ibus", "alsa"],
      "platform": "linux"
    },
    {
      "name": "sdl2",
      "version>=": "2.30.10"
    },
    {
      "name": "spdlog-stdformat",
      "version>=": "1.15.0"
    },
    {
      "$info": "The vulkan headers",
      "name": "vulkan-headers",
      "version>=": "1.3.296.0"
    },
    {
      "name": "vulkan-utility-libraries",
      "version>=": "1.3.296.0"
    },
    {
      "$info": "meta-loader for Vulkan",
      "name": "volk",
      "version>=": "1.3.296"
    }
  ],
  "features": {
    "tests": {
      "description": "Build tests",
      "dependencies": [
        {
          "name": "gtest"
        }
      ]
    }
  }
}
